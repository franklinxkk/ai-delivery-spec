{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/franklinxkk/ai-delivery-spec/schemas/domain-pack.schema.json",
  "title": "AI Delivery Spec Domain Pack Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "domain_id", "name", "coverage", "maturity", "evidence", "known_gaps", "maintainer"],
  "properties": {
    "schema_version": { "const": "5.0.0" },
    "domain_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "knowledge_file": { "type": "string" },
    "applies_when": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "does_not_apply_when": { "type": "array", "items": { "type": "string" } },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge", "scenarios", "behavioral_eval", "expert_review"],
      "properties": {
        "knowledge": { "enum": ["absent", "partial", "structured", "sourced"] },
        "scenarios": { "enum": ["absent", "mocked", "project_sampled", "multi_project"] },
        "behavioral_eval": { "enum": ["not_run", "failed", "partial", "passed"] },
        "expert_review": { "enum": ["not_reviewed", "reviewed_with_gaps", "reviewed"] }
      }
    },
    "maturity": { "enum": ["experimental", "validated", "audited"] },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "location", "status"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["official_source", "mock_scenario", "project_sample", "behavioral_eval", "expert_review", "audit"] },
          "location": { "type": "string" },
          "status": { "enum": ["current", "expired", "failed", "passed", "unknown"] },
          "reviewed_at": { "type": "string", "format": "date-time" },
          "owner": { "type": "string" }
        }
      }
    },
    "known_gaps": { "type": "array", "items": { "type": "string" } },
    "last_verified_at": { "type": ["string", "null"], "format": "date-time" },
    "maintainer": { "type": "string", "minLength": 1 },
    "production_claim": { "enum": ["prohibited", "allowed_with_warning", "allowed"] }
  },
  "allOf": [
    {
      "if": { "properties": { "maturity": { "const": "validated" } } },
      "then": {
        "properties": {
          "coverage": {
            "properties": {
              "knowledge": { "const": "sourced" },
              "scenarios": { "enum": ["project_sampled", "multi_project"] },
              "behavioral_eval": { "const": "passed" },
              "expert_review": { "enum": ["reviewed_with_gaps", "reviewed"] }
            }
          },
          "production_claim": { "enum": ["allowed_with_warning", "allowed"] }
        }
      }
    },
    {
      "if": { "properties": { "maturity": { "const": "audited" } } },
      "then": {
        "properties": {
          "coverage": {
            "properties": {
              "knowledge": { "const": "sourced" },
              "scenarios": { "enum": ["project_sampled", "multi_project"] },
              "behavioral_eval": { "const": "passed" },
              "expert_review": { "const": "reviewed" }
            }
          },
          "production_claim": { "const": "allowed" }
        }
      }
    }
  ]
}
