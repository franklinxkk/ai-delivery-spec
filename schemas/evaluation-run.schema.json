{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/franklinxkk/ai-delivery-spec/schemas/evaluation-run.schema.json",
  "title": "AI Delivery Spec Evaluation Run",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "case_id", "stage", "system", "input_fingerprint", "repetitions", "trial_evidence_refs", "observations", "inventions", "delivery", "context", "evidence_refs", "status"],
  "properties": {
    "schema_version": { "const": "5.0.0" },
    "run_id": { "type": "string", "pattern": "^RUN-[A-Z0-9-]+$" },
    "case_id": { "type": "string", "pattern": "^GH-[A-Z0-9-]+$" },
    "stage": { "enum": ["requirement", "design", "coding_delivery"] },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill_version", "model", "model_settings", "repository_ref"],
      "properties": {
        "skill_version": { "type": "string" },
        "model": { "type": "string" },
        "model_settings": { "type": "string" },
        "repository_ref": { "type": "string" }
      }
    },
    "input_fingerprint": { "type": "string", "minLength": 8 },
    "repetitions": { "type": "integer", "minimum": 1 },
    "trial_evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["obligation_id", "result", "evidence_refs"],
        "properties": {
          "obligation_id": { "type": "string" },
          "result": { "enum": ["satisfied", "partial", "missing", "conflict", "not_run"] },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "inventions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unsupported_business_behaviors", "delivered_business_behaviors", "p0_unsupported"],
      "properties": {
        "unsupported_business_behaviors": { "type": "integer", "minimum": 0 },
        "delivered_business_behaviors": { "type": "integer", "minimum": 0 },
        "p0_unsupported": { "type": "integer", "minimum": 0 }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impacted_acceptance", "failed_impacted_acceptance", "delivered_slices", "reopened_for_spec_mismatch", "accepted_acceptance"],
      "properties": {
        "impacted_acceptance": { "type": "integer", "minimum": 0 },
        "failed_impacted_acceptance": { "type": "integer", "minimum": 0 },
        "delivered_slices": { "type": "integer", "minimum": 0 },
        "reopened_for_spec_mismatch": { "type": "integer", "minimum": 0 },
        "accepted_acceptance": { "type": "integer", "minimum": 0 }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "cross_artifact_switches"],
      "properties": {
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cross_artifact_switches": { "type": "integer", "minimum": 0 },
        "human_navigation_seconds": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["not_run", "partial", "completed"] }
  }
}
