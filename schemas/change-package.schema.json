{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/franklinxkk/ai-delivery-spec/schemas/change-package.schema.json",
  "title": "AI Delivery Spec Change Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_id", "title", "reason", "source_refs", "status", "impacts", "verification"],
  "properties": {
    "schema_version": { "enum": ["5.0.0", "5.1.0"] },
    "change_id": { "type": "string", "pattern": "^CHG-[A-Z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "source_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "status": { "enum": ["proposed", "impact_analysis", "reviewing", "approved", "synchronized", "verified", "baselined", "implemented", "released", "rejected", "superseded"] },
    "baseline_version": { "type": "string" },
    "target_version": { "type": "string" },
    "decision_owner": { "type": "string" },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requester", "requested_at", "authority", "seed_refs", "before", "after"],
      "properties": {
        "requester": { "type": "string", "minLength": 1 },
        "requested_at": { "type": "string", "format": "date-time" },
        "authority": { "type": "string", "minLength": 1 },
        "urgency": { "enum": ["normal", "urgent", "emergency"] },
        "seed_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "before": { "type": "string", "minLength": 1 },
        "after": { "type": "string", "minLength": 1 }
      }
    },
    "diff": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "path", "before", "after", "reason"],
        "properties": {
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "before": {},
          "after": {},
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "impacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules", "flows", "views", "actions", "fields", "states", "events", "acceptance", "data_migration"],
      "properties": {
        "requirements": { "$ref": "#/$defs/impactList" },
        "roles": { "$ref": "#/$defs/impactList" },
        "modules": { "$ref": "#/$defs/impactList" },
        "flows": { "$ref": "#/$defs/impactList" },
        "views": { "$ref": "#/$defs/impactList" },
        "actions": { "$ref": "#/$defs/impactList" },
        "fields": { "$ref": "#/$defs/impactList" },
        "states": { "$ref": "#/$defs/impactList" },
        "events": { "$ref": "#/$defs/impactList" },
        "rules": { "$ref": "#/$defs/impactList" },
        "interfaces": { "$ref": "#/$defs/impactList" },
        "acceptance": { "$ref": "#/$defs/impactList" },
        "tests": { "$ref": "#/$defs/impactList" },
        "defects": { "$ref": "#/$defs/impactList" },
        "evidence": { "$ref": "#/$defs/impactList" },
        "integrations": { "$ref": "#/$defs/impactList" },
        "documentation": { "$ref": "#/$defs/impactList" },
        "data_migration": {
          "type": "object",
          "required": ["required", "strategy", "rollback"],
          "properties": {
            "required": { "type": "boolean" },
            "strategy": { "type": "string" },
            "rollback": { "type": "string" },
            "reconciliation": { "type": "string" }
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "stable_ids_preserved": { "type": "boolean" },
        "deprecated_ids": { "type": "array", "items": { "type": "string" } },
        "replacement_map": { "type": "object", "additionalProperties": { "type": "string" } },
        "consumer_actions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "actor", "decision", "decided_at"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "actor": { "type": "string", "minLength": 1 },
          "decision": { "enum": ["pending", "approved", "approved_with_conditions", "rejected"] },
          "decided_at": { "type": "string", "format": "date-time" },
          "conditions": { "type": "string" },
          "evidence_ref": { "type": "string" }
        }
      }
    },
    "synchronization": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["consumer", "artifact", "version", "status"],
        "properties": {
          "consumer": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pending", "sent", "acknowledged", "failed"] },
          "synchronized_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "audit_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actor", "action", "at", "reason"],
        "properties": {
          "actor": { "type": "string" },
          "action": { "type": "string" },
          "at": { "type": "string", "format": "date-time" },
          "reason": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["acceptance_refs", "regression_refs", "evidence_refs", "result"],
      "properties": {
        "acceptance_refs": { "type": "array", "items": { "type": "string" } },
        "regression_refs": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "result": { "enum": ["not_run", "failed", "partial", "passed"] }
      }
    },
    "release": {
      "type": "object",
      "properties": {
        "rollout": { "type": "string" },
        "rollback_trigger": { "type": "string" },
        "owner": { "type": "string" },
        "released_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "5.1.0" } } },
      "then": { "required": ["request", "diff", "approvals", "synchronization", "audit_log"] }
    }
  ],
  "$defs": {
    "impactList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "change_type", "reason"],
        "properties": {
          "ref": { "type": "string" },
          "change_type": { "enum": ["add", "modify", "deprecate", "remove", "verify_only", "none"] },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
