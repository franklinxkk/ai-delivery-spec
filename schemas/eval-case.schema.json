{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/franklinxkk/ai-delivery-spec/schemas/eval-case.schema.json",
  "title": "AI Delivery Spec Evaluation Case Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_policy", "cases"],
  "properties": {
    "schema_version": { "const": "5.0.0" },
    "selection_policy": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "domain", "repository", "default_branch", "pinned_ref", "source_issue", "captured_requirement", "source_paths", "shape", "risk_signals", "stages"],
        "properties": {
          "id": { "type": "string", "pattern": "^GH-[A-Z0-9-]+$" },
          "domain": { "type": "string", "minLength": 1 },
          "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
          "default_branch": { "type": "string", "minLength": 1 },
          "pinned_ref": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "source_issue": {
            "type": "object",
            "additionalProperties": false,
            "required": ["number", "title", "url", "retrieved_at"],
            "properties": {
              "number": { "type": "integer", "minimum": 1 },
              "title": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "format": "uri" },
              "retrieved_at": { "type": "string", "format": "date" }
            }
          },
          "captured_requirement": { "type": "string", "minLength": 20 },
          "source_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "shape": { "enum": ["greenfield", "brownfield", "hybrid"] },
          "risk_signals": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "stages": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requirement", "design", "coding_delivery"],
            "properties": {
              "requirement": { "$ref": "#/$defs/obligations" },
              "design": { "$ref": "#/$defs/obligations" },
              "coding_delivery": { "$ref": "#/$defs/obligations" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "obligations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "weight", "statement", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^OBL-[A-Z0-9-]+$" },
          "priority": { "enum": ["P0", "P1", "P2"] },
          "weight": { "type": "integer", "minimum": 1, "maximum": 10 },
          "statement": { "type": "string", "minLength": 10 },
          "evidence": { "enum": ["artifact", "repository_probe", "test", "human_review", "source_mapping"] }
        }
      }
    }
  }
}
