{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/franklinxkk/ai-delivery-spec/schemas/assurance-evidence.schema.json",
  "title": "Project Domain Assurance Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "domains"],
  "properties": {
    "schema_version": { "const": "5.0.0" },
    "evidence_id": { "type": "string", "minLength": 1 },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["domain_id", "maturity", "evidence_refs", "production_claim", "reviewer"],
        "properties": {
          "domain_id": { "type": "string", "minLength": 1 },
          "maturity": { "enum": ["validated", "audited"] },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "production_claim": { "enum": ["allowed", "prohibited"] },
          "reviewer": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "qualification", "organization", "signed_at", "signature_ref"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "qualification": { "type": "string", "minLength": 1 },
              "organization": { "type": "string", "minLength": 1 },
              "signed_at": { "type": "string", "format": "date-time" },
              "signature_ref": { "type": "string", "minLength": 1 }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "production_claim": { "const": "allowed" } } },
            "then": { "properties": { "maturity": { "const": "audited" } } }
          }
        ]
      }
    }
  }
}
